{
    "name": "@frak-labs/bootstrap",
    "description": "One-shot bootstrap orchestrator: Postgres + libSQL Drizzle migrations and RustFS bucket provisioning",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "license": "GNU GPL 3.0",
    "scripts": {
        "start": "bun run src/index.ts",
        "dev": "bun run --watch src/index.ts",
        "build": "bun run build.ts",
        "typecheck": "tsgo --noEmit",
        "lint": "biome lint .",
        "format:check": "biome check .",
        "format": "biome check --write .",
        "db:generate:local": "bun --env-file=.env.local drizzle-kit generate",
        "db:generate:dev": "bun --env-file=.env.dev drizzle-kit generate",
        "db:generate:prod": "bun --env-file=.env.prod drizzle-kit generate",
        "db:generate:libsql": "drizzle-kit generate --config drizzle-libsql.config.ts",
        "db:migrate:local": "bun --env-file=.env.local drizzle-kit migrate",
        "db:migrate:dev": "bun --env-file=.env.dev drizzle-kit migrate",
        "db:migrate:prod": "bun --env-file=.env.prod drizzle-kit migrate",
        "db:migrate:libsql": "drizzle-kit migrate --config drizzle-libsql.config.ts",
        "db:studio:local": "bun --env-file=.env.local drizzle-kit studio",
        "db:studio:dev": "bun --env-file=.env.dev drizzle-kit studio",
        "db:studio:prod": "bun --env-file=.env.prod drizzle-kit studio",
        "db:studio:libsql": "drizzle-kit studio --config drizzle-libsql.config.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1030.0",
        "@frak-labs/app-essentials": "workspace:*",
        "@libsql/client": "^0.17.2",
        "drizzle-orm": "^0.45.2",
        "postgres": "^3.4.9"
    },
    "devDependencies": {
        "@swc/core": "^1.15.24",
        "bun-types": "latest",
        "drizzle-kit": "^0.31.10",
        "typescript": "catalog:"
    }
}
