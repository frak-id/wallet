{
  "name": "@frak-labs/backend-elysia",
  "description": "Backend for Frak using Elysia",
  "version": "0.0.17",
  "private": true,
  "type": "module",
  "license": "GNU GPL 3.0",
  "scripts": {
    "lint": "biome lint .",
    "format:check": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "dev": "bun sst dev bun dev:watch",
    "dev:sandbox": "bun run dev:watch",
    "dev:env": "sst shell bun run scripts/envSetup.ts",
    "dev:watch": "bun run --watch src/index.ts",
    "build:docker": "docker build --tag \"elysia-dev\" .",
    "build": "bun build:package",
    "build:package": "bun run build.ts",
    "build:binary-linux-arm64": "bun build --compile --minify --target=bun-linux-arm64 --outfile ./server src/index.ts",
    "build:binary": "bun build --compile --minify --target=bun --outfile ./server src/index.ts",
    "start": "NODE_ENV=production bun dist/index.js",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:generate:libsql": "drizzle-kit generate --config drizzle-libsql.config.ts",
    "db:migrate:libsql": "drizzle-kit migrate --config drizzle-libsql.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/cors": "^1.4.1",
    "@frak-labs/app-essentials": "workspace:*",
    "@frak-labs/core-sdk": "workspace:*",
    "@libsql/client": "^0.17.2",
    "@simplewebauthn/server": "^13.3.0",
    "async-mutex": "^0.5.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "1.4.28",
    "jose": "^6.2.2",
    "ky": "^2.0.0",
    "lightningcss": "^1.32.0",
    "lru-cache": "^11.3.5",
    "nanoid": "^5.1.7",
    "ox": "^0.14.15",
    "permissionless": "^0.3.5",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5",
    "ua-parser-js": "^2.0.9",
    "viem": "catalog:",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@frak-labs/test-foundation": "workspace:*",
    "@swc/core": "^1.15.24",
    "@types/web-push": "^3.6.4",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "catalog:"
  },
  "exports": {
    ".": "./src/index.ts",
    "./infrastructure": "./src/infrastructure/index.ts",
    "./infrastructure/persistence/postgres": "./src/infrastructure/persistence/postgres.ts",
    "./domain/merchant": "./src/domain/merchant/index.ts",
    "./domain/merchant/context": "./src/domain/merchant/context.ts",
    "./domain/merchant/db/schema": "./src/domain/merchant/db/schema.ts",
    "./domain/campaign": "./src/domain/campaign/index.ts",
    "./domain/campaign/context": "./src/domain/campaign/context.ts",
    "./domain/campaign/db/schema": "./src/domain/campaign/db/schema.ts",
    "./domain/campaign-bank": "./src/domain/campaign-bank/index.ts",
    "./domain/campaign-bank/context": "./src/domain/campaign-bank/context.ts",
    "./domain/rewards": "./src/domain/rewards/index.ts",
    "./domain/rewards/schemas": "./src/domain/rewards/schemas/index.ts",
    "./orchestration/schemas": "./src/orchestration/schemas/index.ts",
    "./api/schemas": "./src/api/schemas/index.ts",
    "./domain/pairing": "./src/domain/pairing/index.ts"
  },
  "module": "src/index.ts",
  "main": "./src/index.ts"
}