{
  "name": "@frak-labs/wallet-shared",
  "version": "0.0.6",
  "private": true,
  "type": "module",
  "license": "GNU GPL 3.0",
  "sideEffects": [
    "**/*.css",
    "**/*.css.ts"
  ],
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsgo --noEmit",
    "format": "biome check --write .",
    "i18n:types": "bun run i18next-resources-for-ts interface -i ./src/i18n/locales/en/ -o src/types/i18n/resources.d.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./i18n/locales/en": "./src/i18n/locales/en/index.ts",
    "./i18n/locales/fr": "./src/i18n/locales/fr/index.ts",
    "./polyfills/bigint-serialization": "./src/polyfills/bigint-serialization.ts",
    "./stores/sessionStore": "./src/stores/sessionStore.ts",
    "./stores/clientIdStore": "./src/stores/clientIdStore.ts",
    "./stores/authenticationStore": "./src/stores/authenticationStore.ts",
    "./common": "./src/common/index.ts",
    "./common/analytics": "./src/common/analytics/index.ts",
    "./common/api/backendClient": "./src/common/api/backendClient.ts",
    "./common/utils/safeSession": "./src/common/utils/safeSession.ts",
    "./common/utils/lifecycleEvents": "./src/common/utils/lifecycleEvents.ts",
    "./common/utils/base64url": "./src/common/utils/base64url.ts",
    "./common/hook/useEstimatedReward": "./src/common/hook/useEstimatedReward.ts",
    "./common/hook/useGetSafeSdkSession": "./src/common/hook/useGetSafeSdkSession.ts",
    "./common/hook/useCopyToClipboardWithState": "./src/common/hook/useCopyToClipboardWithState.ts",
    "./common/hook/useMountedTimeout": "./src/common/hook/useMountedTimeout.ts",
    "./common/lib/ua": "./src/common/lib/ua.ts",
    "./pairing": "./src/pairing/index.ts",
    "./pairing/usePersistentPairingClient": "./src/pairing/hook/usePersistentPairingClient.tsx",
    "./identity": "./src/identity/index.ts",
    "./sharing": "./src/sharing/index.ts",
    "./tokens/hook/useGetUserBalance": "./src/tokens/hook/useGetUserBalance.ts",
    "./types": "./src/types/index.ts",
    "./pairing/*": "./src/pairing/*",
    "./authentication/*": "./src/authentication/*",
    "./wallet/*": "./src/wallet/*",
    "./tokens/*": "./src/tokens/*",
    "./providers/*": "./src/providers/*",
    "./styles/*": "./styles/*",
    "./test": "./src/test/factories.ts",
    "./tests/vitest-fixtures": "./tests/vitest-fixtures.ts"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.9",
    "@frak-labs/app-essentials": "workspace:*",
    "@frak-labs/backend-elysia": "workspace:*",
    "@frak-labs/core-sdk": "workspace:*",
    "@frak-labs/design-system": "workspace:*",
    "@vanilla-extract/css": "^1.19.1",
    "@openpanel/web": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "clsx": "^2.1.1",
    "cuer": "^0.0.3",
    "i18next": "^26.0.3",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.577.0",
    "micromark": "^4.0.2",
    "nanoid": "^5.1.7",
    "ox": "^0.14.15",
    "permissionless": "^0.3.5",
    "radash": "^12.1.1",
    "sonner": "^2.0.7",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "^16.5.8",
    "viem": "catalog:",
    "wagmi": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@frak-labs/test-foundation": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vanilla-extract/vite-plugin": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "bun-types": "latest",
    "i18next-resources-for-ts": "^2.0.2",
    "jsdom": "^29.0.0",
    "msw": "^2.12.11",
    "typescript": "catalog:",
    "vitest": "^4.1.4"
  }
}
