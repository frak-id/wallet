{
  "compilerOptions": {
    "lib": ["es2023"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "target": "esnext",
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@backend-utils": ["./services/backend/src/utils/index.ts"],
      "@backend-infrastructure": ["./services/backend/src/infrastructure/index.ts"],
      "@backend-infrastructure/*": ["./services/backend/src/infrastructure/*"],
      "@backend-domain/*": ["./services/backend/src/domain/*"]
    }
  },
  "include": ["**/*.ts", "global.d.ts"],
  "exclude": ["node_modules"]
}
