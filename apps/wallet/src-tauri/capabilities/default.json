{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "enables the default permissions",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "log:default",
        "safe-area-insets:default",
        "biometric:default",
        "fcm:default",
        "deep-link:default",
        "opener:default",
        {
            "identifier": "opener:allow-open-url",
            "allow": [{ "url": "app-settings:*" }]
        },
        "app-settings:allow-open-notification-settings"
    ]
}
