{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "enables the default permissions",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "log:default",
        "safe-area-insets:default",
        "biometric:default",
        "fcm:default",
        "deep-link:default",
        "opener:default",
        "app-settings:allow-open-notification-settings",
        "install-referrer:allow-get-install-referrer",
        "frak-webauthn:default",
        "frak-share:default",
        "clipboard-manager:allow-read-text",
        "recovery-hint:default",
        "frak-crashlytics:default"
    ]
}
