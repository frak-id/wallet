{
  "name": "@frak-labs/nexus-wallet",
  "version": "1.0.30",
  "description": "The simple and cross-platform wallet to centralise your contents.",
  "private": true,
  "sideEffects": [
    "**/*.css",
    "**/*.css.ts"
  ],
  "type": "module",
  "license": "GNU GPL 3.0",
  "scripts": {
    "build": "bun run build:sw && NODE_ENV=production vite build",
    "build:sw": "vite build --mode sw",
    "dev": "bun run build:sw && sst dev vite dev",
    "dev:sandbox": "bun run build:sw && vite dev  --clearScreen false --host",
    "start": "bunx serve dist -p 3000",
    "lint": "biome lint .",
    "format:check": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsgo --noEmit",
    "bundle:check": "sst shell bunx vite-bundle-visualizer",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "TARGET_ENV=local playwright test",
    "test:e2e:dev": "TARGET_ENV=dev playwright test",
    "test:e2e:prod": "TARGET_ENV=prod playwright test",
    "test:e2e:ui": "TARGET_ENV=local playwright test --ui",
    "test:e2e:report": "TARGET_ENV=local playwright test --report show-report",
    "test:e2e:trace": "TARGET_ENV=local playwright test --report show-trace",
    "test:e2e:dev:ui": "TARGET_ENV=dev playwright test --ui",
    "test:e2e:prod:ui": "TARGET_ENV=prod playwright test --ui",
    "test:e2e:dev:codegen": "TARGET_ENV=dev playwright codegen wallet-dev.frak.id",
    "test:light": "playwright test --config playwright.light.config.ts",
    "test:light:ui": "playwright test --config playwright.light.config.ts --ui",
    "test:light:update": "playwright test --config playwright.light.config.ts --update-snapshots",
    "tauri": "tauri",
    "tauri:ios:dev": "sst dev tauri ios dev",
    "tauri:ios:build": "sst shell -- tauri ios build",
    "tauri:ios:build:prod": "sst shell -- tauri ios build --export-method app-store-connect",
    "tauri:android:dev": "sst dev tauri android dev",
    "tauri:android:build": "sst shell -- tauri android build",
    "tauri:version": "./scripts/sync-version.sh"
  },
  "dependencies": {
    "@frak-labs/app-essentials": "workspace:*",
    "@frak-labs/core-sdk": "workspace:*",
    "@frak-labs/design-system": "workspace:*",
    "@frak-labs/frame-connector": "workspace:*",
    "@frak-labs/wallet-shared": "workspace:*",
    "@khmyznikov/pwa-install": "^0.6.3",
    "@tanstack/query-async-storage-persister": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-devtools": "catalog:",
    "@tanstack/react-query-persist-client": "catalog:",
    "@tanstack/react-router": "^1.167.3",
    "@tanstack/router-plugin": "^1.166.12",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-biometric": "^2.3.2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "~2.5.3",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.2",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "ox": "^0.14.15",
    "permissionless": "^0.3.5",
    "radash": "^12.1.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.8",
    "remix-utils": "^9.3.1",
    "sonner": "^2.0.7",
    "tauri-plugin-fcm": "^0.1.9",
    "tauri-plugin-safe-area-insets": "^0.1.0",
    "viem": "catalog:",
    "wagmi": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@frak-labs/test-foundation": "workspace:*",
    "@frak-labs/backend-elysia": "workspace:*",
    "@noble/curves": "^2.0.1",
    "@playwright/test": "^1.58.2",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vanilla-extract/css": "^1.19.1",
    "@vanilla-extract/vite-plugin": "^5.2.0",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "bun-types": "latest",
    "cbor": "^10.0.12",
    "jsdom": "^29.0.0",
    "sst": "3.18.9",
    "typescript": "^6.0.2",
    "vite": "catalog:",
    "vite-plugin-mkcert": "^1.17.10",
    "vite-plugin-remove-console": "^2.2.0",
    "vitest": "^4.1.4"
  }
}
