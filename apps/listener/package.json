{
  "name": "@frak-labs/nexus-listener",
  "version": "0.0.1",
  "description": "SDK iframe listener for Frak Wallet",
  "private": true,
  "sideEffects": [
    "**/*.css",
    "**/*.css.ts"
  ],
  "type": "module",
  "license": "GNU GPL 3.0",
  "scripts": {
    "build": "NODE_ENV=production vite build",
    "start": "bunx serve dist/ -p 3000",
    "dev": "sst dev bun dev:built",
    "dev:sandbox": "vite dev  --clearScreen false --host",
    "dev:built": "sh -c 'trap \"kill 0\" INT TERM EXIT; NODE_ENV=production bun vite build --watch & bun vite preview'",
    "preview": "vite preview",
    "lint": "biome lint .",
    "format:check": "biome check .",
    "format": "biome check --write .",
    "bundle:check": "sst shell bunx vite-bundle-visualizer",
    "typecheck": "tsgo --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@frak-labs/app-essentials": "workspace:*",
    "@frak-labs/core-sdk": "workspace:*",
    "@frak-labs/frame-connector": "workspace:*",
    "@frak-labs/design-system": "workspace:*",
    "@vanilla-extract/css": "^1.19.1",
    "@frak-labs/ui": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@frak-labs/wallet-shared": "workspace:*",
    "@tanstack/query-async-storage-persister": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-persist-client": "catalog:",
    "clsx": "^2.1.1",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.577.0",
    "preact": "^10.29.1",
    "react-i18next": "^16.5.8",
    "normalize.css": "^8.0.1",
    "sonner": "^2.0.7",
    "viem": "catalog:",
    "wagmi": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@frak-labs/backend-elysia": "workspace:*",
    "@frak-labs/test-foundation": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@preact/preset-vite": "^2.10.5",
    "@vanilla-extract/vite-plugin": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "bun-types": "latest",
    "jsdom": "^29.0.0",
    "sst": "3.18.9",
    "typescript": "^6.0.2",
    "vite": "catalog:",
    "vite-plugin-mkcert": "^1.17.10",
    "vite-plugin-remove-console": "^2.2.0",
    "vitest": "^4.1.4"
  }
}
