parameters:
    level: 1
    bootstrapFiles:
        - phpstan-stubs.php
    paths:
        - frakintegration.php
        - classes
        - controllers
        - sql
        - upgrade
    excludePaths:
        - vendor
        - test
        - build (?)
        - dist (?)
    # PrestaShop core surface is declared in `phpstan-stubs.php` (Module,
    # ModuleAdminController, ModuleFrontController, FrontController,
    # Configuration, Tools, Validate, Db, Order, Customer, Currency, Image,
    # Tab, Language, PrestaShopLogger, Hook, Context, Link, Smarty, plus the
    # `pSQL` global function and PS runtime constants). No `ignoreErrors`
    # patterns are needed at level 0 — every PS reference resolves through
    # the stubs. Future bumps to level 1+ may surface real type drift; fix
    # at the call site rather than re-introducing broad ignore patterns.
