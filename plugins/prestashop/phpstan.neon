includes:
    - vendor/prestashop/php-dev-tools/phpstan/ps-module-extension.neon

parameters:
    level: 1
    paths:
        - frakintegration.php
        - classes
        - controllers
        - sql
        - upgrade
    excludePaths:
        - vendor
        - test
        - .cache
        - build (?)
        - dist (?)
    # PrestaShop core surface comes from `prestashop/php-dev-tools` +
    # `_PS_ROOT_DIR_` (set by the `composer analyse` script to a freshly cloned
    # PrestaShop 8.1.7 checkout under `.cache/prestashop-core/`). The
    # extension's `bootstrap.php` requires PS's composer autoload, which is
    # why `composer ps-core:fetch` runs `composer install --no-dev` inside the
    # cloned PS sources before phpstan starts.
