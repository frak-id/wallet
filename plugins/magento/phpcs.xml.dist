<?xml version="1.0"?>
<ruleset name="FrakLabs Magento Module">
    <description>FrakLabs Magento 2 Module Coding Standard</description>
    <rule ref="Magento2"/>
    <file>Block</file>
    <file>Model</file>
    <file>Observer</file>
    <file>Api</file>
    <exclude-pattern>Test/*</exclude-pattern>
    <exclude-pattern>vendor/*</exclude-pattern>
</ruleset>
