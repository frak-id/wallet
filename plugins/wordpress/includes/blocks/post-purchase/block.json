{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "frak/post-purchase",
	"title": "Frak Post-Purchase",
	"description": "Inline card shown on thank-you pages \u2014 congratulates referees and invites referrers to share for rewards.",
	"category": "widgets",
	"icon": "cart",
	"keywords": ["frak", "post purchase", "thank you", "reward", "referral"],
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"textdomain": "frak",
	"attributes": {
		"sharingUrl": { "type": "string", "default": "" },
		"merchantId": { "type": "string", "default": "" },
		"placement": { "type": "string", "default": "" },
		"classname": { "type": "string", "default": "" },
		"variant": { "type": "string", "default": "" },
		"badgeText": { "type": "string", "default": "" },
		"referrerText": { "type": "string", "default": "" },
		"refereeText": { "type": "string", "default": "" },
		"ctaText": { "type": "string", "default": "" },
		"previewVariant": { "type": "string", "default": "referrer" }
	},
	"editorScript": "file:./editor.js",
	"render": "file:./render.php"
}
